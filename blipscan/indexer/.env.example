# Network — devnet (legacy V1 + V2.2) or mainnet-beta (V1.0 only).
# Switching this also flips the default RPC and the IDL the indexer loads.
SOLANA_NETWORK=devnet
# SOLANA_NETWORK=mainnet-beta

# Solana RPC — leave blank to fall back to the public endpoint for the
# selected network. For production, point at Helius/Quicknode (mainnet-beta).
SOLANA_RPC_URL=

# Optional override — pin V2 program ID directly (otherwise derived from
# SOLANA_NETWORK). Mainnet program ID: gfFC2pjvRCALNehRWJb2ce81eDXJMwJdg9W7yeLyBqS
# V2_PROGRAM_ID=

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blipscan
DB_USER=postgres
DB_PASSWORD=your_password_here
