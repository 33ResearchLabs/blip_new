# Solana network — 'devnet' (testing) or 'mainnet-beta' (production).
# Picks the right defaults for V2_PROGRAM_ID and SOLANA_RPC_URL when those
# aren't set explicitly.
SOLANA_NETWORK=devnet

# Solana RPC. For production, use a Helius/QuickNode mainnet endpoint:
#   https://mainnet.helius-rpc.com/?api-key=<key>
SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain program IDs. Leave commented to use defaults baked per network.
# Mainnet v1.0 V2: gfFC2pjvRCALNehRWJb2ce81eDXJMwJdg9W7yeLyBqS
# Devnet V2:       6AG4ccUtM1YPcVmkMrMTuhjEtY8E7p5qwT4nud6mea87
# V2_PROGRAM_ID=
# V1_PROGRAM_ID=

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blipscan
DB_USER=postgres
DB_PASSWORD=your_password_here
