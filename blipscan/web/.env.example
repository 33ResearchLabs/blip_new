# Invite-code gate (comma-separated; optional expiry YYYY-MM-DD after colon)
# Example: SCAN_INVITE_CODES=BLIP-MERCHANT-01,BLIP-TESTER-A1:2026-08-01
# Leave unset to disable the gate entirely.
SCAN_INVITE_CODES=

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blipscan
DB_USER=postgres
DB_PASSWORD=your_password_here
