# Network — controls Solscan cluster suffix on outbound links.
# devnet → links carry ?cluster=devnet; mainnet-beta → no suffix.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blipscan
DB_USER=postgres
DB_PASSWORD=your_password_here
