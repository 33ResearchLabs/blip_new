# ══════════════════════════════════════════════════════════════════════════════
# BLIP MONEY — PRODUCTION ENVIRONMENT TEMPLATE
# ══════════════════════════════════════════════════════════════════════════════
# Copy to .env.local on your production server and fill in ALL values.
# The app will refuse to start if required vars are missing.
#
# Generate secrets with:
#   openssl rand -hex 32        (for CORE_API_SECRET, ADMIN_SECRET)
#   openssl rand -base64 24     (for passwords)
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=your-db-host.com
DB_PORT=5432
DB_NAME=settle
DB_USER=settle_app
DB_PASSWORD=CHANGE_ME                # REQUIRED — never leave empty in production

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.blipmoney.com
NEXT_PUBLIC_BLIPSCAN_URL=https://scan.blipmoney.com
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://app.blipmoney.com

# ── Core API (Fastify backend) ────────────────────────────────────────────────
USE_CORE_API=1
CORE_API_URL=http://localhost:4010   # or internal hostname if separate containers
CORE_API_PORT=4010
CORE_API_SECRET=                     # REQUIRED — run: openssl rand -hex 32
NEXT_PUBLIC_CORE_WS_URL=wss://api.blipmoney.com/ws/orders

# ── Auth Secrets ──────────────────────────────────────────────────────────────
ADMIN_SECRET=                        # REQUIRED — run: openssl rand -hex 32
ADMIN_PASSWORD=                      # REQUIRED — run: openssl rand -base64 24
COMPLIANCE_PASSWORD=                 # REQUIRED — run: openssl rand -base64 24

# ── Pusher (Real-time WebSocket) ──────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=                       # From Pusher dashboard
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=               # From Cloudinary dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Solana ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=          # Helius/Quicknode mainnet RPC URL
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_EMBEDDED_WALLET=true

# ── Blip Protocol on Solana mainnet (deployed 2026-04-27, v1.0) ──────────────
# These three constants come from the on-chain deploy. They're hard-coded as
# fallbacks in src/lib/solana/v2/config.ts, but setting them here makes the
# wiring explicit and lets you switch program IDs without a code change.
NEXT_PUBLIC_ANCHOR_PROGRAM_ID=gfFC2pjvRCALNehRWJb2ce81eDXJMwJdg9W7yeLyBqS
NEXT_PUBLIC_TREASURY_WALLET=D3oNcCQ7yareg3UkzK7AQ4qk8oax9AbkZFVJcakD9vSP
NEXT_PUBLIC_PROTOCOL_CONFIG_PDA=2K1ucbvLoS3S7H8Ft8dsLbmxo39pmwnGY4WRN9R8KJL9

# Tiered fees — frontend exposes 3 tier buttons; caller picks one per trade
# within [min, max]. Program enforces an on-chain hard cap of 1000 (10%).
NEXT_PUBLIC_FEE_BPS_DEFAULT=200      # 2.0% — standard tier
NEXT_PUBLIC_FEE_BPS_MIN=150          # 1.5% — cheap tier
NEXT_PUBLIC_FEE_BPS_MAX=250          # 2.5% — fastest tier

# ── Hard launch caps (first 4 weeks of mainnet — limits blast radius) ────────
# Enforced in client code at trade-creation time. Lift after 4 stable weeks.
NEXT_PUBLIC_MAX_TRADE_USD=5000       # max single-trade size during launch
NEXT_PUBLIC_MAX_DAILY_USER_USD=50000 # max per-user daily volume during launch

# ── Price Engine ──────────────────────────────────────────────────────────────
PRICE_AUTHORITY_KEYPAIR=             # Solana keypair hex — generate fresh for production
PRICE_MAX_DEVIATION=0.05             # 5% max deviation (tighter than dev 15%)
PRICE_GUARDRAILS_ENABLED=true        # MUST be true in production
PRICE_FEED_POLL_MS=30000

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                  # From @BotFather — rotate if compromised

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=              # From sentry.io project settings
SENTRY_AUTH_TOKEN=                   # For source map uploads (optional)
