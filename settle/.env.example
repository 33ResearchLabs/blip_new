# Database Configuration (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=settle
DB_USER=zeus
DB_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Pusher
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key

# Blipscan
NEXT_PUBLIC_BLIPSCAN_URL=http://localhost:3003

# Mode
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_EMBEDDED_WALLET=true

# Core API
USE_CORE_API=1
CORE_API_URL=http://localhost:4010
CORE_API_PORT=4010
CORE_API_SECRET=your_core_api_secret
NEXT_PUBLIC_CORE_WS_URL=ws://localhost:4010/ws/orders

# Redis (for BullMQ receipt queue — optional, app works without it)
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Resend (Password Reset Emails)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Feature Flags
FF_SYSTEM_CHAT=1

# Auth Migration — set to 'true' to REQUIRE tokens on sensitive routes (escrow, payments)
# When false (default): tokens preferred but headers accepted with warnings
AUTH_TOKEN_REQUIRED=false