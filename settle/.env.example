# Database Configuration (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=settle
DB_USER=zeus
DB_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Pusher
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key

# Backend Signer — server-side keypair for automated on-chain escrow refunds
# Base58-encoded secret key. Only needs SOL for tx fees, does not hold user funds.
# Generate: solana-keygen new --no-bip39-passphrase --outfile /dev/stdout | tail -1
# Then base58-encode the secret key bytes.
# Leave empty to disable auto-refund (users must claim from app).
# BACKEND_SIGNER_KEYPAIR=

# Blipscan
NEXT_PUBLIC_BLIPSCAN_URL=http://localhost:3003

# Mode
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_EMBEDDED_WALLET=true

# Core API
USE_CORE_API=1
CORE_API_URL=http://localhost:4010
CORE_API_PORT=4010
CORE_API_SECRET=your_core_api_secret
NEXT_PUBLIC_CORE_WS_URL=ws://localhost:4010/ws/orders

# Redis (for BullMQ receipt queue — optional, app works without it)
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Resend (Password Reset Emails)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Dev Access Lock — set a password to gate the entire app behind a shared team password.
# Leave empty/unset to disable the lock entirely.
# DEV_ACCESS_PASSWORD=your_team_password

# Feature Flags
FF_SYSTEM_CHAT=1

# Auth Migration — REQUIRE tokens on sensitive routes (escrow, payments)
# Production defaults to true. Set to 'false' ONLY for local development.
AUTH_TOKEN_REQUIRED=true

# TOTP 2FA — optional, falls back to ADMIN_SECRET if not set
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# TOTP_ENCRYPTION_KEY=your_32_byte_base64_key
TOTP_ISSUER=Blip
TOTP_WINDOW=1
# Onboard Form Webhook — shared secret used by the Google Apps Script
# trigger on the merchant onboarding form's responses sheet to authenticate
# POSTs to /api/waitlist/onboard-form-webhook. Set both this env var and the
# matching Script Property on the Google side. Rotate together.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ONBOARD_FORM_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Waitlist threat-detection external APIs (Phase B)
# ----------------------------------------------------------------------------
# Each integration is OPTIONAL — when the key is unset, the corresponding
# signals simply don't fire and the threat score is computed from the
# remaining signals. No error, no degraded UX.

# IPQS (IPQualityScore) — IP reputation, VPN/Tor/proxy detection, fraud score.
# Free tier: 5,000 requests/month. Sign up: https://www.ipqualityscore.com/
# Used for: IP_DATACENTER_ASN, IP_VPN_DETECTED, IP_TOR_EXIT,
#           IP_HIGH_FRAUD_SCORE, IP_GEO_COUNTRY_MISMATCH signals.
# IPQS_API_KEY=

# HIBP (Have I Been Pwned) — email-breach exposure check.
# Paid: ~$3.50/month per domain. Get key: https://haveibeenpwned.com/API/Key
# Used for: EMAIL_BREACH_EXPOSURE, EMAIL_BREACH_RECENT signals.
# HIBP_API_KEY=
