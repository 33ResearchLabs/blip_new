{
  "name": "blip-watchdog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Permissionless watcher bot: escalates stale PaymentSent trades to Disputed and finalizes timed-out Disputed trades via resolve_dispute_timeout.",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.29.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.3",
    "bs58": "^5.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
